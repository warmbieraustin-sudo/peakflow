{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peakflow.local/schemas/activity.schema.json",
  "title": "PeakFlow activity",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "start_date_local",
    "moving_time_sec",
    "distance_m",
    "avg_hr",
