{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peakflow.local/schemas/athlete_day.schema.json",
  "title": "PeakFlow athlete_day",
  "type": "object",
  "required": ["date", "source", "recovery", "load", "activity_summary", "freshness", "raw_refs"],
  "properties": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "source": { "type": "string" },
    "recovery": {
      "type": "object",
      "required": ["weight_kg", "resting_hr", "hrv", "sleep_seconds", "sleep_score"],
      "properties": {
        "weight_kg": { "type": ["number", "null"] },
        "resting_hr": { "type": ["number", "null"] },
        "hrv": { "type": ["number", "null"] },
        "sleep_seconds": { "type": ["number", "null"] },
        "sleep_score": { "type": ["number", "null"] }
      },
      "additionalProperties": false
    },
    "load": {
      "type": "object",
      "required": ["ctl", "atl", "ramp_rate", "daily_training_load"],
      "properties": {
        "ctl": { "type": ["number", "null"] },
        "atl": { "type": ["number", "null"] },
        "ramp_rate": { "type": ["number", "null"] },
        "daily_training_load": { "type": ["number", "null"] }
      },
      "additionalProperties": false
    },
    "activity_summary": {
      "type": "object",
      "required": ["count", "total_calories", "total_kj", "avg_np"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "total_calories": { "type": "number" },
        "total_kj": { "type": "number" },
        "avg_np": { "type": ["number", "null"] }
      },
      "additionalProperties": false
    },
    "freshness": {
      "type": "object",
      "required": ["is_fresh", "reason", "updated", "age_minutes", "max_age_minutes"],
      "properties": {
        "is_fresh": { "type": "boolean" },
        "reason": { "type": "string" },
        "updated": { "type": ["string", "null"] },
        "age_minutes": { "type": ["number", "null"] },
        "max_age_minutes": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "raw_refs": {
      "type": "object",
      "required": ["wellness_updated", "activity_ids"],
      "properties": {
        "wellness_updated": { "type": ["string", "null"] },
        "activity_ids": {
          "type": "array",
          "items": { "type": ["string", "null"] }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
